# Chrysalis — Self-Compounding Agent
# Copy to .env and fill in values

# Agent wallet private key (earns USDC from queries, manages vault)
AGENT_PRIVATE_KEY=0x...

# Human wallet private key (separate from agent — funds demo queries)
# Can be same as AGENT_PRIVATE_KEY for testing (agent can't pay itself via x402)
HUMAN_PRIVATE_KEY=0x...

# Venice AI — private LLM inference, no data retention
VENICE_API_KEY=your-venice-api-key

# Optional: Base Sepolia RPC (defaults to public endpoint)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Optional: GitHub token for higher API rate limits
GITHUB_TOKEN=ghp_...
